{
  "name": "openrouter-credit-monitor",
  "version": "1.0.0",
  "author": "钟智强",
  "description": "定时检查 OpenRouter 额度余额，低于阈值时通过 AWS SNS 与 Telegram 告警。TypeScript 函数式实现，可部署为 AWS Lambda。",
  "license": "MIT",
  "private": false,
  "keywords": [
    "openrouter",
    "aws-lambda",
    "sns",
    "telegram",
    "typescript",
    "monitoring"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/credit.test.ts test/scheduler.test.ts",
    "test:credit": "node --import tsx --test test/credit.test.ts",
    "test:scheduler": "node --import tsx --test test/scheduler.test.ts",
    "start": "tsx src/local.ts",
    "cron": "tsx src/cron.ts",
    "build": "esbuild src/handler.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/index.js --external:@aws-sdk/*",
    "package": "npm run build && cd dist && zip -q -r ../function.zip index.js && echo '已生成 function.zip'"
  },
  "dependencies": {
    "@aws-sdk/client-sns": "^3.700.0",
    "undici": "^6.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
