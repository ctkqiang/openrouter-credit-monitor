# 复制为 .env 并填入真实值（.env 已被 .gitignore 忽略，不会提交）

# 【必填】应用标识名称，用于在通知中标明告警来源应用。
APP_NAME=MY_APP_OPENROUTER

# 【可选】运行环境/上下文标识（如 local / staging / production / lambda）。默认 local。
APP_ENV=local

# 【可选】日志输出级别：DEBUG | INFO | WARN | ERROR。默认 INFO。
LOG_LEVEL=INFO

# 【必填】OpenRouter API 密钥。请勿提交到仓库；生产环境建议用 AWS Secrets Manager 注入。
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 【必填】Telegram 机器人 Token（@BotFather 获取）
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 【必填】Telegram 目标会话 ID
TELEGRAM_CHAT_ID=123456789

# 【必填】AWS SNS 主题 ARN
SNS_TOPIC_ARN=arn:aws:sns:ap-southeast-1:000000000000:openrouter-alerts

# 【可选】余额告警阈值，默认 100
CREDIT_THRESHOLD=100

# 【可选】本地监控轮询间隔（分钟），默认 5
CHECK_INTERVAL_MINUTES=5

# 【可选】HTTP 代理，对应 curl 的 -x 参数；仅本地调试用，部署到 Lambda 时请删除
# OPENROUTER_PROXY=http://127.0.0.1:9000
